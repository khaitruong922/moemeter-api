{
	"name": "moemeter-api",
	"main": "src/index.ts",
	"compatibility_flags": ["nodejs_compat"],
	"compatibility_date": "2024-09-23",
	"triggers": {
		"crons": ["0 3,7,11,15,19,23 * * *", "*/3 3,7,11,15,19,23 * * *"]
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	},
  "$schema": "./node_modules/wrangler/config-schema.json",
  "services": [
    {
      "binding": "BOOKMETER_API",
      "service": "bookmeter-api"
    }
  ]
}
